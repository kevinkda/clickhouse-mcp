# ---------------------------------------------------------------------------
# clickhouse-mcp environment template.
#
# This MCP server is a READ-ONLY query surface over a USA-market ClickHouse
# warehouse (1.49B-row 1m bars + L1 aggregates + L2 materialised indicators).
#
# SECURITY (financial data — see docs/SECURITY.md + docs/THREAT_MODEL.md):
#   * Use a DEDICATED read-only ClickHouse account, NOT an admin account.
#     Create it on the ClickHouse side with SELECT-only grants, e.g.:
#         CREATE USER mcp_readonly IDENTIFIED BY '<password>'
#             SETTINGS readonly = 1;
#         GRANT SELECT ON usa.* TO mcp_readonly;
#   * Credentials are read from env ONLY — never logged, never repr'd.
#   * run_safe_sql is DISABLED by default (see below).
#
# Copy this file to .env (which is gitignored) and edit the values below.
# ---------------------------------------------------------------------------

# REQUIRED — ClickHouse connection (dedicated read-only account recommended).
CLICKHOUSE_MCP_HOST=localhost
CLICKHOUSE_MCP_HTTP_PORT=8123
CLICKHOUSE_MCP_USER=mcp_readonly
CLICKHOUSE_MCP_PASSWORD=  # pragma: allowlist secret
# OPTIONAL — default database (tables are referenced as <db>.<table>).
CLICKHOUSE_MCP_DATABASE=usa
# OPTIONAL — use TLS for the HTTP(S) interface (true/false; default false).
CLICKHOUSE_MCP_SECURE=false

# OPTIONAL — connection + query resource guardrails.
# Connect timeout (seconds) for establishing the HTTP session (default 5).
CLICKHOUSE_MCP_CONNECT_TIMEOUT=5
# Per-query server-side execution timeout in seconds (default 30).
CLICKHOUSE_MCP_MAX_EXECUTION_TIME=30
# Per-query server-side max result rows (default 100000).
CLICKHOUSE_MCP_MAX_RESULT_ROWS=100000

# OPTIONAL — raw-SQL escape hatch. DISABLED BY DEFAULT (security-critical).
# When false (default) run_safe_sql refuses every query and only the
# parameterised structured tools are usable. Set to true ONLY if you
# understand the risk; even then run_safe_sql still enforces SELECT-only,
# single-statement, DDL/DML rejection, forced LIMIT, readonly=1, and the
# resource guardrails above.
CLICKHOUSE_MCP_ALLOW_RAW_SQL=false

# OPTIONAL — log level (default: WARNING).
LOG_LEVEL=WARNING
